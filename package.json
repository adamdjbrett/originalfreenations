{
  "name": "11ty-headline",
  "version": "1.0.0",
  "description": "Headline — the Ghost local-news theme, converted to Eleventy (v4) with Nunjucks, Pagefind search, light/dark mode and Pages CMS. Originally a Ghost theme by Ghost Foundation; 11ty conversion by Adam DJ Brett.",
  "type": "module",
  "scripts": {
    "dev": "eleventy --serve --quiet",
    "start": "eleventy --serve --quiet",
    "build": "eleventy",
    "serve": "eleventy --serve",
    "debug": "cross-env DEBUG=Eleventy* eleventy",
    "clean": "rm -rf _site"
  },
  "keywords": [
    "eleventy",
    "11ty",
    "nunjucks",
    "ghost-theme",
    "headline",
    "pagefind",
    "pagescms"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/adamdjbrett/11ty-Headline.git"
  },
  "author": {
    "name": "Adam DJ Brett",
    "email": "info@adamdjbrett.com",
    "url": "https://adamdjbrett.com/"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@11ty/eleventy": "4.0.0-alpha.10",
    "@awesome.me/buildawesome": "^4.0.0-alpha.10",
    "@xmit.co/xmit": "0.5.2-0",
    "cross-env": "^10.1.0",
    "js-yaml": "^4.1.0",
    "luxon": "^3.7.2",
    "pagefind": "^1.4.0"
  },
  "dependencies": {
    "@uncenter/eleventy-plugin-toc": "^2.1.2",
    "markdown-it": "^14.3.0",
    "markdown-it-anchor": "^9.2.1",
    "markdown-it-footnote": "^4.0.0"
  },
  "allowScripts": {
    "@xmit.co/xmit@0.5.2-0": true
  }
}
