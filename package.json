{
  "name": "originalfreenations",
  "version": "1.0.0",
  "description": "Original Free Nations — originalfreenations.com. Cutting-edge research for Indigenous Peoples' liberation. Eleventy v4 site using the 11ty-Headline theme.",
  "type": "module",
  "scripts": {
    "dev": "npx @11ty/eleventy --serve --quiet",
    "start": "npx @11ty/eleventy --serve --quiet",
    "build": "npx @11ty/eleventy",
    "serve": "npx @11ty/eleventy --serve",
    "debug": "cross-env DEBUG=Eleventy* npx @11ty/eleventy",
    "clean": "rm -rf _site"
  },
  "keywords": [
    "originalfreenations",
    "indigenous",
    "doctrine-of-discovery",
    "eleventy",
    "11ty",
    "nunjucks",
    "headline",
    "pagefind",
    "pagescms"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/adamdjbrett/originalfreenations.git"
  },
  "author": {
    "name": "Adam DJ Brett",
    "email": "adam@adamdjbrett.com",
    "url": "https://adamdjbrett.com/"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@11ty/eleventy": "4.0.0-alpha.10",
    "@awesome.me/buildawesome": "^4.0.0-alpha.10",
    "cross-env": "^10.1.0",
    "js-yaml": "^4.1.0",
    "json5": "2.2.3",
    "luxon": "^3.7.2",
    "pagefind": "^1.4.0"
  }
}
