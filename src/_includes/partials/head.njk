{#- Everything inside <head>: SEO, no-flash theme script, styles, Pagefind. -#}
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="generator" content="{{ eleventy.generator }}">

{%- set pageTitle = title or metadata.title %}
{%- set pageDesc = description or custom_excerpt or excerpt or metadata.description %}
{%- set pageImage = feature_image or cover_image or metadata.cover_image %}
<title>{% if title %}{{ title }} — {{ metadata.title }}{% else %}{{ metadata.title }}{% endif %}</title>
<meta name="description" content="{{ pageDesc }}">
<link rel="canonical" href="{{ metadata.url }}{{ page.url or '/' }}">

{#- Open Graph / Twitter -#}
<meta property="og:site_name" content="{{ metadata.title }}">
<meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDesc }}">
{%- if pageImage %}
<meta property="og:image" content="{% if pageImage.startsWith('http') %}{{ pageImage }}{% else %}{{ metadata.url }}{{ pageImage }}{% endif %}">
<meta name="twitter:card" content="summary_large_image">
{%- else %}
<meta name="twitter:card" content="summary">
{%- endif %}

<link rel="icon" href="{{ metadata.icon or '/favicon.svg' }}"{% if not metadata.icon %} type="image/svg+xml"{% endif %}>
<link rel="alternate" type="application/atom+xml" title="{{ metadata.title }} (Atom)" href="/feed.xml">
<link rel="alternate" type="application/rss+xml" title="{{ metadata.title }} (RSS)" href="/feed/feed.rss">
<link rel="alternate" type="application/feed+json" title="{{ metadata.title }} (JSON)" href="/feed/feed.json">

{#- Linked Organization, WebSite, and Blog nodes on every page. -#}
<script type="application/ld+json">{{ schema.siteGraph | dump | safe }}</script>
{%- if layout == 'layouts/post.njk' %}
{%- set ldAuthors = authors | resolveAuthors(authors) %}
{%- set imageAbs = "" %}
{%- if feature_image %}{% set imageAbs = feature_image if feature_image.startsWith('http') else metadata.url + feature_image %}{% endif %}
{%- set postLd = { title: title, description: pageDesc, url: metadata.url + page.url, date: (page.date | htmlDateString), lang: schema.language, image: imageAbs, authors: ldAuthors, siteUrl: metadata.url, siteName: metadata.title, blogId: schema.blogId, publisher: schema.publisher } | postingLd %}
<script type="application/ld+json">{{ postLd | dump | safe }}</script>
{#- Zotero: Highwire (citation_*) + Dublin Core metadata for harvestability. -#}
<link rel="type" href="https://schema.org/BlogPosting">
<meta name="citation_title" content="{{ title | escape }}">
{%- for a in ldAuthors %}
<meta name="citation_author" content="{{ a.name | escape }}">
{%- endfor %}
<meta name="citation_date" content="{{ page.date | htmlDateString }}">
<meta name="citation_publication_date" content="{{ page.date | htmlDateString }}">
<meta name="citation_abstract" content="{{ pageDesc | escape }}">
<meta name="citation_fulltext_html_url" content="{{ metadata.url }}{{ page.url }}">
<meta name="citation_public_url" content="{{ metadata.url }}{{ page.url }}">
<meta name="citation_publisher" content="{{ metadata.organization.name | escape }}">
<meta name="citation_language" content="{{ schema.language }}">
{%- for tag in tags | publicTags %}
<meta name="citation_keywords" content="{{ tag | escape }}">
{%- endfor %}
{%- for a in ldAuthors %}
<meta name="author" content="{{ a.name | escape }}">
{%- endfor %}
<meta name="DC.title" content="{{ title | escape }}">
{%- for a in ldAuthors %}
<meta name="DC.creator" content="{{ a.name | escape }}">
{%- endfor %}
<meta name="DC.date" content="{{ page.date | htmlDateString }}">
<meta name="DC.language" content="{{ schema.language }}">
<meta name="DC.publisher" content="{{ metadata.organization.name | escape }}">
<meta name="DC.type" content="Text">
<meta name="DC.source" content="{{ metadata.title }}">
{%- endif %}

{#- No-flash: set the colour scheme before first paint. -#}
<script>
	(function () {
		try {
			var stored = localStorage.getItem("headline-color-scheme");
			var scheme = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
			document.documentElement.setAttribute("data-theme", scheme);
		} catch (e) {
			document.documentElement.setAttribute("data-theme", "{{ theme.default_color_scheme or 'light' }}");
		}
	})();
</script>

{#- Cache reusable styles instead of repeating them in every HTML document.
    Pagefind Component UI is no longer loaded in <head> — it is lazy-loaded
    on first search intent by /assets/js/pagefind-loader.js (see default.njk). -#}
<link rel="stylesheet" href="/assets/built/screen.css">
<link rel="stylesheet" href="/assets/css/fonts.css">
<link rel="stylesheet" href="/assets/css/darkmode.css">
<link rel="stylesheet" href="/assets/css/site.css">
