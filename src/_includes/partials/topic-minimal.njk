{#- Expects `topic`: a term from collections.topics ({ name, slug, count, posts }),
    whose `posts` array is already newest-first. Do not re-filter here. -#}
<section class="gh-topic gh-topic-minimal">
    <header class="gh-topic-header">
        <h2 class="gh-topic-name">
            <a href="/tag/{{ topic.slug }}/">{{ topic.name }}</a>
        </h2>
        <a class="gh-topic-link" href="/tag/{{ topic.slug }}/">{{ "More" | t }}<span class="gh-sr-only"> {{ topic.name }}</span> {% include "partials/icons/arrow.njk" %}</a>
    </header>

    <div class="gh-topic-content">
        {% for post in (topic.posts | head(5)) %}
            {% include "partials/loop-minimal.njk" %}
        {% endfor %}
    </div>
</section>
