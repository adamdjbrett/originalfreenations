---
layout: layouts/default.njk
bodyClass: tag-template
pagination:
  data: collections.categories
  size: 1
  alias: topic
permalink: "/category/{{ topic.slug }}/"
eleventyComputed:
  title: "{{ topic.name }}"
---
{#- One page per CATEGORY — the taxonomy migrated from WordPress, kept separate
    from tags. `topic` carries its own newest-first `posts` array (built in the
    single taxonomy pass in eleventy.config.js), so this template never filters
    collections.posts. Markup mirrors tags.njk on purpose: same theme classes. -#}
<main class="gh-main gh-outer">
	<div class="gh-inner">
		<section class="gh-pagehead">
			<h1 class="gh-pagehead-title">{{ topic.name }}</h1>
		</section>

		<div class="gh-topic gh-topic-grid">
			<div class="gh-topic-content gh-feed">
				{% for post in topic.posts %}
					{% include "partials/loop-grid.njk" %}
				{% endfor %}
			</div>
		</div>
	</div>
</main>
